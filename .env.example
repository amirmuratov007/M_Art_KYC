# Public Supabase values required by the browser client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase key. Never expose this value in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Admin access.
HEIMDALL_ADMIN_SECRET=

# Analyst workspace access.
HEIMDALL_ANALYST_LOGIN=
HEIMDALL_ANALYST_PASSWORD=
HEIMDALL_ANALYST_SECRET=
HEIMDALL_ANALYST_ROLE=analyst

# Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SUPABASE_LEADS_TABLE=heimdall_leads

# Legacy Telegram aliases used by older integrations, if still needed.
TG_TOKEN=
TG_CHAT_ID=

# Optional AI analysis.
AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# Optional server storage for Risk Intelligence.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=
