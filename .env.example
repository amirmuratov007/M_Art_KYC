# Public Supabase values required by the browser client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase key. Never expose this value in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Admin access.
HEIMDALL_ADMIN_SECRET=

# Telegram notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Legacy Telegram aliases used by older integrations, if still needed.
TG_TOKEN=
TG_CHAT_ID=

# AI report drafting. Use one provider, or set AI_PROVIDER explicitly.
AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
